{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "customer-route": {
        "ClusterId": "customer-cluster",
        "Match": { "Path": "/customers/{**catch-all}" }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/orders/{**catch-all}" }
      },
      "rules-route": {
        "ClusterId": "rules-cluster",
        "Match": { "Path": "/rules/{**catch-all}" }
      },
      "reporting-route": {
        "ClusterId": "reporting-cluster",
        "Match": { "Path": "/reporting/{**catch-all}" }
      },
      "audit-route": {
        "ClusterId": "audit-cluster",
        "Match": { "Path": "/audit/{**catch-all}" }
      },
      "cost-route": {
        "ClusterId": "cost-cluster",
        "Match": { "Path": "/costs/{**catch-all}" }
      }
    },
    "Clusters": {
      "customer-cluster": {
        "Destinations": {
          "primary": { "Address": "http://customer-service.apps.svc.cluster.local" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "primary": { "Address": "http://order-service.apps.svc.cluster.local" }
        }
      },
      "rules-cluster": {
        "Destinations": {
          "primary": { "Address": "http://rules-service.apps.svc.cluster.local" }
        }
      },
      "reporting-cluster": {
        "Destinations": {
          "primary": { "Address": "http://reporting-service.apps.svc.cluster.local" }
        }
      },
      "audit-cluster": {
        "Destinations": {
          "primary": { "Address": "http://audit-service.apps.svc.cluster.local" }
        }
      },
      "cost-cluster": {
        "Destinations": {
          "primary": { "Address": "http://cost-service.apps.svc.cluster.local" }
        }
      }
    }
  }
}
