@page
@model FlowCore.EhrApp.Pages.IndexModel
@{ ViewData["Title"] = "Dashboard"; }

<!-- Hero Banner -->
<div class="hero-card card border-0 mb-4 fade-in">
    <div class="card-body p-4 py-5">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 py-2 px-3"><i class="bi bi-circle-fill me-1 pulse" style="font-size:.45rem;"></i>System Online</span>
                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 py-2 px-3"><i class="bi bi-boxes me-1"></i>Containerized</span>
                </div>
                <h2 class="fw-bold mb-2" style="font-size: 1.75rem;">Welcome to <span style="background: linear-gradient(135deg, #6387f1, #22d3ee); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">FlowCore EHR</span></h2>
                <p class="mb-4" style="color: var(--fc-text-muted); line-height: 1.6;">Electronic Health Records platform running on <strong style="color: var(--fc-cyan);">Azure Kubernetes Service</strong> with <strong style="color: var(--fc-accent);">PostgreSQL</strong> &mdash; managing patients, encounters, medications, lab results, and appointments in real-time.</p>
                <div class="d-flex gap-2 flex-wrap">
                    <a href="/Patients/Create" class="btn btn-primary px-4"><i class="bi bi-person-plus-fill me-1"></i>New Patient</a>
                    <a href="/Appointments" class="btn btn-outline-light"><i class="bi bi-calendar-check me-1"></i>Appointments</a>
                    <a href="/Encounters" class="btn btn-outline-light"><i class="bi bi-clipboard2-pulse me-1"></i>Encounters</a>
                </div>
            </div>
            <div class="col-lg-5 text-center d-none d-lg-block">
                <div style="position:relative; height: 160px;">
                    <i class="bi bi-heart-pulse-fill" style="font-size: 7rem; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); opacity:.08; color: var(--fc-cyan);"></i>
                    <i class="bi bi-heart-pulse-fill" style="font-size: 4rem; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); opacity:.15; color: var(--fc-accent);"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl fade-in fade-in-d1">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-people-fill"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@Model.PatientCount</div>
                    <div style="color: var(--fc-text-muted);" class="small">Total Patients</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl fade-in fade-in-d2">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info"><i class="bi bi-calendar-check-fill"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@Model.UpcomingAppointments</div>
                    <div style="color: var(--fc-text-muted);" class="small">Upcoming Appts</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl fade-in fade-in-d3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-clipboard2-pulse-fill"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@Model.ActiveEncounters</div>
                    <div style="color: var(--fc-text-muted);" class="small">Active Encounters</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl fade-in fade-in-d4">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-capsule"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@Model.ActiveMedications</div>
                    <div style="color: var(--fc-text-muted);" class="small">Active Medications</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl fade-in fade-in-d5">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-danger bg-opacity-10 text-danger"><i class="bi bi-droplet-half"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@Model.PendingLabs</div>
                    <div style="color: var(--fc-text-muted);" class="small">Pending Labs</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Two-column: Appointments + Activity -->
<div class="row g-4 mb-4">
    <div class="col-lg-7 fade-in">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-calendar-event-fill me-2" style="color: var(--fc-cyan);"></i>Today's Appointments</h6>
                <a href="/Appointments" class="btn btn-sm btn-outline-secondary">View All <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
            <div class="card-body p-0">
                @if (Model.TodayAppointments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead><tr><th class="ps-3">Time</th><th>Patient</th><th>Provider</th><th>Status</th></tr></thead>
                            <tbody>
                                @foreach (var apt in Model.TodayAppointments)
                                {
                                    <tr>
                                        <td class="ps-3 fw-medium">@apt.ScheduledDate.ToString("h:mm tt")</td>
                                        <td><a href="/Patients/Detail?id=@apt.PatientId" class="text-decoration-none">@apt.Patient.FullName</a></td>
                                        <td style="color: var(--fc-text-muted);">@apt.Provider</td>
                                        <td>
                                            @{var cls = apt.Status == "Checked-In" ? "success" : apt.Status == "Scheduled" ? "info" : "secondary";}
                                            <span class="badge bg-@cls bg-opacity-25 text-@(cls)-emphasis">@apt.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5" style="color: var(--fc-text-muted);">
                        <i class="bi bi-calendar-x fs-1 d-block mb-2 opacity-25"></i>
                        <p class="mb-0">No appointments scheduled for today</p>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5 fade-in">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-activity me-2" style="color: var(--fc-amber);"></i>Recent Activity</h6>
            </div>
            <div class="card-body">
                @if (Model.RecentAlerts.Any())
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var alert in Model.RecentAlerts)
                        {
                            <div class="d-flex align-items-start gap-3">
                                <div class="activity-dot mt-1 bg-@(alert.DotColor == "red" ? "danger" : alert.DotColor == "yellow" ? "warning" : "success")"></div>
                                <div class="flex-grow-1 small" style="line-height:1.5;">@alert.Message</div>
                                <div class="small text-nowrap" style="color: var(--fc-text-muted);">@alert.TimeAgo</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4" style="color: var(--fc-text-muted);"><p class="mb-0">No recent activity</p></div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Recent Patients -->
<div class="card fade-in">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-people-fill me-2" style="color: var(--fc-accent);"></i>Recent Patients</h6>
        <a href="/Patients" class="btn btn-sm btn-outline-secondary">View All <i class="bi bi-arrow-right ms-1"></i></a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead><tr><th class="ps-3">MRN</th><th>Name</th><th>Age</th><th>Gender</th><th>Insurance</th><th>Last Visit</th></tr></thead>
                <tbody>
                    @foreach (var p in Model.RecentPatients)
                    {
                        <tr>
                            <td class="ps-3"><code class="text-info">@p.MRN</code></td>
                            <td><a href="/Patients/Detail?id=@p.Id" class="text-decoration-none fw-medium">@p.FullName</a></td>
                            <td>@p.Age</td>
                            <td style="color: var(--fc-text-muted);">@p.Gender</td>
                            <td style="color: var(--fc-text-muted);">@(p.InsuranceProvider ?? "—")</td>
                            <td style="color: var(--fc-text-muted);">@(p.Encounters.OrderByDescending(e => e.EncounterDate).FirstOrDefault()?.EncounterDate.ToString("MMM dd, yyyy") ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
