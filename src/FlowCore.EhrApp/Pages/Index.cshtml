@page
@model FlowCore.EhrApp.Pages.IndexModel
@{ ViewData["Title"] = "Dashboard"; }

<!-- Hero Banner -->
<div class="card border-0 mb-4" style="background: linear-gradient(135deg, #1a365d 0%, #0f172a 60%, #164e63 100%);">
    <div class="card-body p-4">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h2 class="fw-bold mb-2"><i class="bi bi-heart-pulse me-2 text-info"></i>Welcome to FlowCore EHR</h2>
                <p class="text-secondary mb-3">Electronic Health Records system running on <strong class="text-info">Azure Kubernetes Service</strong> with <strong class="text-primary">PostgreSQL</strong>. Manage patients, encounters, medications, lab results, and appointments in real-time.</p>
                <div class="d-flex gap-2 flex-wrap">
                    <a href="/Patients/Create" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i>New Patient</a>
                    <a href="/Appointments" class="btn btn-outline-light"><i class="bi bi-calendar-check me-1"></i>Appointments</a>
                    <a href="/Encounters" class="btn btn-outline-light"><i class="bi bi-clipboard2-pulse me-1"></i>Encounters</a>
                </div>
            </div>
            <div class="col-lg-4 text-center d-none d-lg-block">
                <i class="bi bi-hospital" style="font-size: 6rem; opacity: .15;"></i>
            </div>
        </div>
    </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-people-fill"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@Model.PatientCount</div>
                    <div class="text-secondary small">Total Patients</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info"><i class="bi bi-calendar-check"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@Model.UpcomingAppointments</div>
                    <div class="text-secondary small">Upcoming Appointments</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-clipboard2-pulse"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@Model.ActiveEncounters</div>
                    <div class="text-secondary small">Active Encounters</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-capsule"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@Model.ActiveMedications</div>
                    <div class="text-secondary small">Active Medications</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-danger bg-opacity-10 text-danger"><i class="bi bi-droplet-half"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@Model.PendingLabs</div>
                    <div class="text-secondary small">Pending Lab Results</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Two-column: Appointments + Activity -->
<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-calendar-event me-2 text-info"></i>Today's Appointments</h6>
                <a href="/Appointments" class="btn btn-sm btn-outline-secondary">View All</a>
            </div>
            <div class="card-body p-0">
                @if (Model.TodayAppointments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead><tr><th class="ps-3">Time</th><th>Patient</th><th>Provider</th><th>Status</th></tr></thead>
                            <tbody>
                                @foreach (var apt in Model.TodayAppointments)
                                {
                                    <tr>
                                        <td class="ps-3">@apt.ScheduledDate.ToString("h:mm tt")</td>
                                        <td><a href="/Patients/Detail?id=@apt.PatientId" class="text-decoration-none">@apt.Patient.FullName</a></td>
                                        <td>@apt.Provider</td>
                                        <td>
                                            @{var cls = apt.Status == "Checked-In" ? "success" : apt.Status == "Scheduled" ? "info" : "secondary";}
                                            <span class="badge bg-@cls bg-opacity-25 text-@(cls)-emphasis">@apt.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-secondary">
                        <i class="bi bi-calendar-x fs-1 d-block mb-2 opacity-50"></i>
                        <p class="mb-0">No appointments scheduled for today</p>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-activity me-2 text-warning"></i>Recent Activity</h6>
            </div>
            <div class="card-body">
                @if (Model.RecentAlerts.Any())
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var alert in Model.RecentAlerts)
                        {
                            <div class="d-flex align-items-start gap-2">
                                <div class="activity-dot mt-1 bg-@(alert.DotColor == "red" ? "danger" : alert.DotColor == "yellow" ? "warning" : "success")"></div>
                                <div class="flex-grow-1 small">@alert.Message</div>
                                <div class="text-secondary small text-nowrap">@alert.TimeAgo</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-secondary"><p class="mb-0">No recent activity</p></div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Recent Patients -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-people me-2 text-primary"></i>Recent Patients</h6>
        <a href="/Patients" class="btn btn-sm btn-outline-secondary">View All</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead><tr><th class="ps-3">MRN</th><th>Name</th><th>Age</th><th>Gender</th><th>Insurance</th><th>Last Visit</th></tr></thead>
                <tbody>
                    @foreach (var p in Model.RecentPatients)
                    {
                        <tr>
                            <td class="ps-3"><code class="text-info">@p.MRN</code></td>
                            <td><a href="/Patients/Detail?id=@p.Id" class="text-decoration-none fw-medium">@p.FullName</a></td>
                            <td>@p.Age</td>
                            <td>@p.Gender</td>
                            <td>@(p.InsuranceProvider ?? "—")</td>
                            <td>@(p.Encounters.OrderByDescending(e => e.EncounterDate).FirstOrDefault()?.EncounterDate.ToString("MMM dd, yyyy") ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
