@page
@model FlowCore.EhrApp.Pages.PatientsModel
@{ ViewData["Title"] = "Patients"; }

<div class="d-flex justify-content-between align-items-center mb-4 fade-in">
    <form method="get" class="d-flex gap-2">
        <div class="input-group" style="width:340px;">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" name="search" value="@Model.Search" placeholder="Search by name or MRN..." class="form-control" />
        </div>
        <button type="submit" class="btn btn-outline-secondary"><i class="bi bi-funnel me-1"></i>Search</button>
    </form>
    <a href="/Patients/Create" class="btn btn-primary"><i class="bi bi-person-plus-fill me-1"></i>New Patient</a>
</div>

<div class="card fade-in">
    <div class="card-body p-0">
        @if (Model.Patients.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3">MRN</th><th>Name</th><th>Date of Birth</th><th>Age</th><th>Gender</th>
                            <th>Phone</th><th>Insurance</th><th>Blood Type</th><th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Patients)
                        {
                            <tr>
                                <td class="ps-3"><code class="text-info">@p.MRN</code></td>
                                <td>
                                    <a href="/Patients/Detail?id=@p.Id" class="text-decoration-none fw-semibold">@p.FullName</a>
                                </td>
                                <td>@p.DateOfBirth.ToString("MMM dd, yyyy")</td>
                                <td>@p.Age</td>
                                <td>
                                    <span class="badge bg-@(p.Gender == "Female" ? "pink" : p.Gender == "Male" ? "primary" : "secondary") bg-opacity-10 text-@(p.Gender == "Female" ? "danger" : p.Gender == "Male" ? "primary" : "secondary")-emphasis">
                                        <i class="bi bi-@(p.Gender == "Female" ? "gender-female" : p.Gender == "Male" ? "gender-male" : "gender-ambiguous") me-1"></i>@p.Gender
                                    </span>
                                </td>
                                <td>@(p.Phone ?? "—")</td>
                                <td>@(p.InsuranceProvider ?? "—")</td>
                                <td>
                                    @if (p.BloodType != null)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger-emphasis">@p.BloodType</span>
                                    }
                                    else { <span class="text-secondary">—</span> }
                                </td>
                                <td class="text-end pe-3">
                                    <a href="/Patients/Detail?id=@p.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye me-1"></i>View</a>
                                    <a href="/Patients/Edit?id=@p.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil me-1"></i>Edit</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-secondary">
                <i class="bi bi-people fs-1 d-block mb-2 opacity-50"></i>
                <p class="mb-0">No patients found</p>
            </div>
        }
    </div>
    <div class="card-footer text-secondary small">
        <i class="bi bi-info-circle me-1"></i>Showing @Model.Patients.Count patient(s)
    </div>
</div>
