@page
@model FlowCore.EhrApp.Pages.PatientEditModel
@{ ViewData["Title"] = "Edit Patient"; }

@if (Model.Patient == null)
{
    <div class="text-center py-5 text-secondary"><i class="bi bi-exclamation-triangle fs-1 d-block mb-2"></i><p>Patient not found</p></div>
    return;
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0 fw-semibold"><i class="bi bi-pencil-square me-2 text-warning"></i>Edit Patient — @Model.Patient.FullName</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Patient.Id" />
                    <input type="hidden" asp-for="Patient.MRN" />
                    <input type="hidden" asp-for="Patient.CreatedAt" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">First Name <span class="text-danger">*</span></label>
                            <input asp-for="Patient.FirstName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Last Name <span class="text-danger">*</span></label>
                            <input asp-for="Patient.LastName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Date of Birth <span class="text-danger">*</span></label>
                            <input asp-for="Patient.DateOfBirth" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Gender <span class="text-danger">*</span></label>
                            <select asp-for="Patient.Gender" class="form-select" required>
                                <option value="">Select...</option>
                                <option>Male</option><option>Female</option><option>Other</option>
                            </select>
                        </div>
                        <div class="col-12"><hr class="my-1" /><h6 class="text-secondary mt-2"><i class="bi bi-telephone me-1"></i>Contact Information</h6></div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input asp-for="Patient.Email" type="email" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone</label>
                            <input asp-for="Patient.Phone" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Address</label>
                            <input asp-for="Patient.Address" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">City</label>
                            <input asp-for="Patient.City" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Postal Code</label>
                            <input asp-for="Patient.PostalCode" class="form-control" />
                        </div>
                        <div class="col-12"><hr class="my-1" /><h6 class="text-secondary mt-2"><i class="bi bi-heart-pulse me-1"></i>Medical Information</h6></div>
                        <div class="col-md-6">
                            <label class="form-label">Blood Type</label>
                            <select asp-for="Patient.BloodType" class="form-select">
                                <option value="">Unknown</option>
                                <option>A+</option><option>A-</option><option>B+</option><option>B-</option>
                                <option>AB+</option><option>AB-</option><option>O+</option><option>O-</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Insurance Provider</label>
                            <input asp-for="Patient.InsuranceProvider" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Insurance Policy Number</label>
                            <input asp-for="Patient.InsurancePolicyNumber" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Allergies</label>
                            <textarea asp-for="Patient.Allergies" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                    <hr />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
                        <a href="/Patients/Detail?id=@Model.Patient.Id" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
