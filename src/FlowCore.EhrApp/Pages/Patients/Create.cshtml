@page
@model FlowCore.EhrApp.Pages.PatientCreateModel
@{ ViewData["Title"] = "New Patient"; }

<div style="max-width:700px;">
    <div class="card">
        <div class="card-header"><h2>Register New Patient</h2></div>
        <div class="card-body">
            <form method="post">
                <div class="form-row">
                    <div class="form-group">
                        <label>First Name *</label>
                        <input asp-for="Patient.FirstName" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Last Name *</label>
                        <input asp-for="Patient.LastName" class="form-control" required />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Date of Birth *</label>
                        <input asp-for="Patient.DateOfBirth" type="date" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Gender *</label>
                        <select asp-for="Patient.Gender" class="form-control" required>
                            <option value="">Select...</option>
                            <option>Male</option><option>Female</option><option>Other</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Email</label>
                        <input asp-for="Patient.Email" type="email" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Phone</label>
                        <input asp-for="Patient.Phone" class="form-control" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Address</label>
                    <input asp-for="Patient.Address" class="form-control" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>City</label>
                        <input asp-for="Patient.City" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Postal Code</label>
                        <input asp-for="Patient.PostalCode" class="form-control" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Blood Type</label>
                        <select asp-for="Patient.BloodType" class="form-control">
                            <option value="">Unknown</option>
                            <option>A+</option><option>A-</option><option>B+</option><option>B-</option>
                            <option>AB+</option><option>AB-</option><option>O+</option><option>O-</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Insurance Provider</label>
                        <input asp-for="Patient.InsuranceProvider" class="form-control" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Insurance Policy Number</label>
                    <input asp-for="Patient.InsurancePolicyNumber" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Allergies</label>
                    <textarea asp-for="Patient.Allergies" class="form-control" placeholder="List known allergies..."></textarea>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Register Patient</button>
                    <a href="/Patients" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
