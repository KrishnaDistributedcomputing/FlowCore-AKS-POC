<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FlowCore EHR</title>
    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏥</text></svg>">
</head>
<body>
    @{
        var path = ViewContext.HttpContext.Request.Path.ToString();
        bool isHome = path == "/" || path == "";
    }
    <div class="d-flex">
        <!-- ── Sidebar ── -->
        <nav class="sidebar d-flex flex-column flex-shrink-0 p-3 text-white" style="width: var(--fc-sidebar-w, 270px); min-height: 100vh; position: fixed; top: 0; left: 0; z-index: 1040;">
            <!-- Brand -->
            <a href="/" class="d-flex align-items-center text-white text-decoration-none sidebar-brand mb-3 pb-3">
                <i class="bi bi-heart-pulse-fill fs-4 me-2"></i>
                <span class="fs-5">FlowCore EHR</span>
            </a>

            <!-- Navigation -->
            <div class="text-uppercase small fw-bold mb-2" style="color: rgba(136,150,179,.5); font-size:.7rem; letter-spacing:.1em; padding-left:.9rem;">Navigation</div>
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a href="/" class="nav-link @(isHome ? "active" : "")"><i class="bi bi-grid-1x2-fill me-2"></i>Dashboard</a>
                </li>
                <li>
                    <a href="/Patients" class="nav-link @(path.StartsWith("/Patients") ? "active" : "")"><i class="bi bi-people-fill me-2"></i>Patients</a>
                </li>
                <li>
                    <a href="/Appointments" class="nav-link @(path.StartsWith("/Appointments") ? "active" : "")"><i class="bi bi-calendar-check-fill me-2"></i>Appointments</a>
                </li>
                <li>
                    <a href="/Encounters" class="nav-link @(path.StartsWith("/Encounters") ? "active" : "")"><i class="bi bi-clipboard2-pulse-fill me-2"></i>Encounters</a>
                </li>
                <li>
                    <a href="/Medications" class="nav-link @(path.StartsWith("/Medications") ? "active" : "")"><i class="bi bi-capsule me-2"></i>Medications</a>
                </li>
                <li>
                    <a href="/LabResults" class="nav-link @(path.StartsWith("/LabResults") ? "active" : "")"><i class="bi bi-droplet-half me-2"></i>Lab Results</a>
                </li>
            </ul>

            <!-- Sidebar Footer -->
            <div class="sidebar-footer text-center small">
                <div class="d-flex justify-content-center gap-2 mb-2">
                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25"><i class="bi bi-circle-fill me-1 pulse" style="font-size:.5rem;"></i>AKS Live</span>
                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25"><i class="bi bi-database-fill me-1"></i>PgSQL</span>
                </div>
                <div style="color: rgba(136,150,179,.4); font-size:.7rem;">FlowCore POC &middot; .NET 8</div>
            </div>
        </nav>

        <!-- ── Main Content ── -->
        <main class="flex-grow-1" style="margin-left: var(--fc-sidebar-w, 270px);">
            <!-- Top Navbar -->
            <nav class="top-navbar navbar navbar-expand sticky-top px-4 py-2">
                <h1 class="navbar-brand mb-0 fs-5 fw-bold" style="color: var(--fc-text);">@ViewData["Title"]</h1>
                <div class="ms-auto d-flex align-items-center gap-3">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-10 d-flex align-items-center gap-1 py-2 px-3"><i class="bi bi-cloud-fill"></i>Azure AKS</span>
                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-10 d-flex align-items-center gap-1 py-2 px-3"><i class="bi bi-database-fill"></i>PostgreSQL</span>
                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-10 d-flex align-items-center gap-1 py-2 px-3"><i class="bi bi-box-fill"></i>Redis</span>
                </div>
            </nav>
            <!-- Page Content -->
            <div class="p-4">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
