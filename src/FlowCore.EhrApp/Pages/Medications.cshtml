@page
@model FlowCore.EhrApp.Pages.MedicationsModel
@{ ViewData["Title"] = "Medications"; }

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-capsule"></i></div>
                <div><div class="fs-3 fw-bold">@Model.ActiveCount</div><div class="text-secondary small">Active Medications</div></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-danger bg-opacity-10 text-danger"><i class="bi bi-x-circle"></i></div>
                <div><div class="fs-3 fw-bold">@Model.DiscontinuedCount</div><div class="text-secondary small">Discontinued</div></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-people-fill"></i></div>
                <div><div class="fs-3 fw-bold">@Model.UniquePatients</div><div class="text-secondary small">Patients on Meds</div></div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0 fw-semibold"><i class="bi bi-capsule me-2 text-success"></i>All Medications</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead><tr><th class="ps-3">Patient</th><th>Medication</th><th>Dosage</th><th>Frequency</th><th>Route</th><th>Prescribed By</th><th>Start Date</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var m in Model.Medications)
                    {
                        <tr>
                            <td class="ps-3"><a href="/Patients/Detail?id=@m.PatientId" class="text-decoration-none fw-medium">@m.Patient.FullName</a></td>
                            <td class="fw-semibold">@m.Name</td>
                            <td><span class="badge bg-secondary bg-opacity-25">@m.Dosage</span></td>
                            <td>@m.Frequency</td>
                            <td>@(m.Route ?? "—")</td>
                            <td>@(m.PrescribedBy ?? "—")</td>
                            <td>@m.StartDate.ToString("MMM dd, yyyy")</td>
                            <td><span class="badge bg-@(m.Status == "Active" ? "success" : m.Status == "Discontinued" ? "danger" : "secondary") bg-opacity-25 text-@(m.Status == "Active" ? "success" : m.Status == "Discontinued" ? "danger" : "secondary")-emphasis">@m.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer text-secondary small">
        <i class="bi bi-info-circle me-1"></i>Showing @Model.Medications.Count medication(s)
    </div>
</div>
